#include<iostream>
using namespace std;

class Employee

{  
       protected:
		float basicSalary;
		float bonus;
		public:
			void inputSalarydetails()
			{
			  cout<<" Basic salary : ";
			  cin>>basicSalary;
			  cout<<" Bonus : ";
			  cin>>bonus;	
			}
			float CalculateSalary()
			{
				return basicSalary+bonus;
		    }
};
class Manager:public Employee
{   public:
	float CalculateSalary()
	{
		if(bonus<5000)
		{
			cout<<" Bonus too low . ";
			return -1;
		}
		else {
		
		float total=(basicSalary+bonus)*1.20;
		return total;
	         }
	}
};
int main()
{
	Manager M;
	M.inputSalarydetails();
	 float salary = M.CalculateSalary();
	 if(salary!=-1)
	 {
	 	cout<<" total salary ( with 20% allowance ): Rs."<<salary<<endl;
	 	
	 }
	return 0;}
